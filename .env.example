# .env.example
# Copy this file to .env and replace the values with your own keys.

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Ollama Endpoint Configuration
# Use local host for local runs, or replace with a public endpoint for cloud apps.
OLLAMA_URL=http://localhost:11434

# Security Controls
# Setting this to true allows voice commands to dynamically execute Python scripts via subprocess.
# WARNING: Keep this false when deploying to a public URL to prevent remote code execution (RCE) attacks.
ALLOW_CODE_EXECUTION=false
